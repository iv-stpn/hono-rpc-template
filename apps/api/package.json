{
  "name": "@app/api",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./dist/apps/api/src/index.d.ts"
    }
  },
  "scripts": {
    "dev": "wrangler dev --port 8787",
    "deploy": "wrangler deploy",
    "build:types": "rm -rf dist && tsc -p tsconfig.build.json --declarationDir dist",
    "typecheck": "bun run build:types && tsc --noEmit",
    "db:migrate:local": "wrangler d1 migrations apply hono_rpc_db --local",
    "db:migrate": "wrangler d1 migrations apply hono_rpc_db --remote",
    "db:reset:local": "rm -rf .wrangler/state && bun run db:migrate:local",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@app/schemas": "workspace:*",
    "@app/utils": "workspace:*",
    "@hono/zod-validator": "0.8.0",
    "argon2-wasm-edge": "1.0.23",
    "hono": "4.12.27",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260701.1",
    "wrangler": "4.106.0",
    "typescript": "5.6.3"
  }
}
