{
  "name": "@app/api",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "dev": "wrangler dev --port 8787",
    "deploy": "wrangler deploy",
    "build:types": "rm -rf dist && tsc -p tsconfig.build.json --declarationDir dist 2>&1 | grep -v 'TS6059' || true && rm -f ../../packages/utils/src/*.d.ts ../../packages/schemas/src/*.d.ts",
    "typecheck": "bun run build:types && tsc --noEmit",
    "db:migrate:local": "wrangler d1 migrations apply hono_rpc_db --local",
    "db:migrate": "wrangler d1 migrations apply hono_rpc_db --remote",
    "db:reset:local": "rm -rf .wrangler/state && bun run db:migrate:local"
  },
  "dependencies": {
    "@app/schemas": "workspace:*",
    "@app/utils": "workspace:*",
    "@hono/zod-validator": "^0.8.0",
    "argon2-wasm-edge": "^1.0.23",
    "hono": "^4.6.14",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "wrangler": "^4.0.0",
    "typescript": "^5.6.3"
  }
}
